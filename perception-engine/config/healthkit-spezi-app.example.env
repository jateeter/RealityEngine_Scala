# Spezi HealthKit bridge app configuration.
# Use these values in the iOS app as scheme environment variables,
# an app-local .env file, or as source values for Info.plist substitution.

# Do not use localhost from the simulator or iPhone unless PE runs inside that
# same runtime. For simulator-to-Mac with the Scala PE, http://127.0.0.1:5000
# may work. For a physical iPhone, use the Mac's LAN IP.
# Deprecated compatibility example: http://<mac-lan-ip>:3300 only when PE is
# explicitly started on that compatibility port.
PE_BASE_URL=http://<mac-lan-ip>:5000
PE_HEALTHKIT_ENDPOINT=/api/integrations/healthkit/ingest
HEALTHKIT_BRIDGE_ID=healthkit-ios-bridge
HEALTHKIT_BRIDGE_TOKEN=<dev-token>
