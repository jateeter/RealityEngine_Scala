# RealityEngine_Scala operational defaults
# Copy to .env and uncomment lines you need to override.

# Native service ports for the Scala deployment.
REALITY_ENGINE_PORT=5001
PERCEPTION_ENGINE_PORT=5000
VECTOR_DIMENSION=7680

# Active machine repository from RealityEngine_Machines.
MACHINES_DIR=../RealityEngine_Machines/machines

# Optional local AI integration.
LOCAL_AI_API_URL=http://localhost:4000
LOCAL_AI_MACHINES_DIR=../localAIStack/data/machines

# Unified Qdrant vector store owned by localAIStack.
QDRANT_URL=http://localhost:4333

# PE integration registry — CI-generated config (health + ACP/OpenClaw).
# When set, the Scala PE loads this file at startup and routes
# /api/integrations/healthkit/ingest, /api/integrations/carekit/ingest, and
# /api/integrations/completions payloads to the declared perceptual-space regions.
INTEGRATIONS_CONFIG=../RealityEngine_CI/config/integrations.json

# ACP / OpenClaw xACP handoff wiring for Scala PE.
ACP_ENABLED=true
ACP_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
ACP_SESSION_KEY=agent:main:main
ACP_TARGET_AGENT=openclaw
ACP_COMPLETION_SOURCE_MAPPING_ID=acp-openclaw-completion
